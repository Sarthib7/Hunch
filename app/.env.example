# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase — dashboard: https://supabase.com/dashboard/project/pqeqkksdscynmxjlztzx
# Public — safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the client. Settings -> API -> service_role key
# (the SECRET key — a long eyJ... JWT or an sb_secret_... key, NOT the publishable one).
SUPABASE_SERVICE_ROLE_KEY=

# The Hunch staking pool — an Organisation avatar that receives CRC stakes.
NEXT_PUBLIC_POOL_ADDRESS=

# Optional — protects /api/cron. Callers must send `Authorization: Bearer <value>`.
# Leave unset in local dev.
CRON_SECRET=

# Optional — voting round length in milliseconds. Defaults to 8h (28800000).
# Set to 120000 for a 2-minute demo round.
HUNCH_ROUND_MS=

# Optional — per-voter cooldown in milliseconds. Defaults to 1h (3600000).
# Set to 0 to disable, or e.g. 60000 for a 1-minute demo. To keep the client
# countdown in sync with the server check, set the same value on both:
HUNCH_VOTER_COOLDOWN_MS=
NEXT_PUBLIC_HUNCH_VOTER_COOLDOWN_MS=

# Optional but required for automated reward payouts. Same private key as
# POOL_DEPLOYER_KEY (the pool's controller). Without this set, payout rows
# are inserted as 'pending' when the crowd wins and the operator must run a
# script to actually send the CRC. Whoever holds this key can drain the pool —
# for a real-money deployment, swap to a Safe with a payout module instead.
POOL_PAYOUT_KEY=
