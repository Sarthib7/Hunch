# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase — dashboard: https://supabase.com/dashboard/project/pqeqkksdscynmxjlztzx
# Public — safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the client. Settings -> API -> service_role key
# (the SECRET key — a long eyJ... JWT or an sb_secret_... key, NOT the publishable one).
SUPABASE_SERVICE_ROLE_KEY=

# The Quorum staking pool — an Organisation avatar that receives CRC stakes.
NEXT_PUBLIC_POOL_ADDRESS=

# Optional — protects /api/cron. Callers must send `Authorization: Bearer <value>`.
# Leave unset in local dev.
CRON_SECRET=

# Optional — voting round length in milliseconds. Defaults to 8h (28800000).
# Set to 120000 for a 2-minute demo round.
QUORUM_ROUND_MS=
